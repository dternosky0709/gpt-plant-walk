# Required in the serverless deployment environment.
PDFBOLT_API_KEY=replace-with-your-private-pdfbolt-api-key

# Optional. Set to the exact production app origin for stricter CORS.
# Example: https://gpt-plant-walk.vercel.app
ALLOWED_ORIGIN=*

# Reserved for the future live AI provider. Do not put real secrets in this file.
OPENAI_API_KEY=replace-with-your-private-openai-api-key
